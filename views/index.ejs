<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>Live Tracker</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#1a73e8">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" crossorigin="anonymous"/>
</head>
<body>
    <div id="map"></div>

    <!-- top bar -->
    <div id="topbar">
        <div id="status-dot"></div>
        <span id="status-text">Getting location...</span>
    </div>

    <!-- bottom panel -->
    <div id="bottom-panel">
        <div id="user-info">
            <div class="user-card" id="my-card">
                <div class="user-dot me"></div>
                <div class="user-details">
                    <span class="user-label">You</span>
                    <span class="user-coords" id="my-coords">Locating...</span>
                </div>
            </div>
            <div class="divider"></div>
            <div class="user-card" id="other-card">
                <div class="user-dot other"></div>
                <div class="user-details">
                    <span class="user-label">Other</span>
                    <span class="user-coords" id="other-coords">Waiting...</span>
                </div>
            </div>
        </div>
        <div id="distance-bar" style="display:none">
            📏 Distance: <span id="distance-text">--</span>
        </div>
        <div id="btn-row">
            <button id="btn-me">📍 My Location</button>
            <button id="btn-both">👥 Show Both</button>
            <button id="btn-other" disabled>🎯 Other's Location</button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.socket.io/4.8.3/socket.io.min.js" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
</body>
</html>
